# ── Telegram ──────────────────────────────────────────────
# Create a bot: message @BotFather on Telegram → /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (comma-separated for multiple users)
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# ── Workspace ─────────────────────────────────────────────
# Parent directory containing your coding projects
WORKSPACE_BASE_DIR=~/Code

# ── Forum Topics ──────────────────────────────────────────
# Use Telegram Forum Topics for per-project isolation
# Requires a supergroup with Topics enabled in group settings
USE_TOPICS=true

# ── Antigravity ───────────────────────────────────────────
# (Optional) Full path to the Antigravity executable
# Needed on Linux or if Antigravity is not on your PATH
# ANTIGRAVITY_PATH=/opt/applications/antigravity.AppImage

# ── Behavior ──────────────────────────────────────────────
# Auto-approve file edit dialogs (can be toggled at runtime via /autoaccept)
AUTO_APPROVE_FILE_EDITS=false

# ── Advanced ─────────────────────────────────────────────
# Log verbosity: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# DOM extraction mode: structured, legacy (default: structured)
# EXTRACTION_MODE=structured
